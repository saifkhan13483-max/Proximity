# ─────────────────────────────────────────────────────────────────────────────
# Proximity Credit Repair — Frontend Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: add these as Environment Variables in the project settings.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Client SDK ───────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ── API URL ───────────────────────────────────────────────────────────────────
# Production: URL of your deployed Firebase Functions API
# Format: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/api
# Local dev (with Firebase Emulator): http://localhost:5001/YOUR_PROJECT_ID/us-central1/api
VITE_API_URL=https://us-central1-your-project-id.cloudfunctions.net/api

# ── App Environment ───────────────────────────────────────────────────────────
NODE_ENV=development
