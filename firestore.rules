rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Proximity Credit Repair — Firestore Security Rules
//
// Architecture: All reads/writes go through the Firebase client SDK directly
// from the browser. Firestore rules are the sole security layer.
//
// Collections:
//   users/{userId}                          — user profiles (doc ID == Firebase Auth UID)
//   users/{userId}/disputePackages/{id}     — AI-generated dispute letter packages
//   users/{userId}/creditReviews/{id}       — AI credit review history
//   contacts/{contactId}                    — contact form submissions (doc ID == UUID)
//   services/{serviceId}                    — service offerings (doc ID == slug)
//
// Roles:
//   Admin — role field on the user's Firestore document == 'admin'
//   User  — any authenticated user without the admin role
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Reads the role from the user's Firestore document.
    // NOTE: The app stores role in Firestore (not as a Firebase custom claim),
    // so we must use get() here rather than request.auth.token.role.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── users/{userId} ──────────────────────────────────────────────────────
    //
    // Schema:
    //   id          : string  (equals the document ID / Firebase Auth UID)
    //   name        : string
    //   email       : string
    //   createdAt   : string  (ISO-8601)
    //   plan        : string
    //   role        : string  ('user' | 'admin')
    //   creditScore : number | null
    //
    // Access:
    //   READ   — owner or admin
    //   CREATE — owner only (role must be 'user')
    //   UPDATE — owner (safe fields only) OR admin (any field)
    //   DELETE — admin only

    match /users/{userId} {

      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.id   == userId
        && request.resource.data.role == 'user'
        && request.resource.data.keys().hasAll([
             'id', 'name', 'email', 'createdAt', 'plan', 'role'
           ])
        && !('passwordHash' in request.resource.data);

      // Owners may update safe fields only (cannot escalate role, change email, or id).
      // Admins may update any field (plan, creditScore, etc.).
      allow update: if
        (
          isOwner(userId)
          && request.resource.data.role  == resource.data.role
          && request.resource.data.email == resource.data.email
          && request.resource.data.id    == resource.data.id
          && !('passwordHash' in request.resource.data)
        )
        || isAdmin();

      allow delete: if isAdmin();

      // ─── users/{userId}/disputePackages/{packageId} ───────────────────────
      //
      // Schema:
      //   createdAt   : timestamp
      //   status      : 'Generated' | 'Mailed' | 'Under Review' | 'Resolved'
      //   letterCount : number
      //   bureaus     : string[]
      //   itemNames   : string[]
      //   letters     : array of letter objects
      //
      // Access:
      //   READ, CREATE, UPDATE — owner only
      //   DELETE              — owner or admin

      match /disputePackages/{packageId} {
        allow read, create: if isOwner(userId);
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status']);
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ─── users/{userId}/creditReviews/{reviewId} ──────────────────────────
      //
      // Schema:
      //   createdAt    : timestamp
      //   firstName    : string
      //   currentScore : string
      //   goalScore    : string
      //   result       : object (CreditReviewResult)
      //
      // Access:
      //   READ, CREATE — owner only
      //   DELETE       — owner or admin

      match /creditReviews/{reviewId} {
        allow read, create: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // ─── contacts/{contactId} ────────────────────────────────────────────────
    //
    // Schema:
    //   id                : string  (UUID)
    //   fullName          : string
    //   email             : string
    //   phone             : string
    //   serviceOfInterest : string
    //   message           : string
    //   status            : 'new' | 'in-progress' | 'resolved'
    //   createdAt         : string  (ISO-8601)
    //
    // Access:
    //   CREATE — anyone (public contact form, no auth required)
    //   READ   — admin only
    //   UPDATE — admin only (status changes)
    //   DELETE — admin only

    match /contacts/{contactId} {

      allow create: if
        request.resource.data.keys().hasAll([
          'id', 'fullName', 'email', 'message', 'status', 'createdAt'
        ])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() <= 200
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 254
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.status == 'new';

      allow read, update, delete: if isAdmin();
    }

    // ─── services/{serviceId} ─────────────────────────────────────────────────
    //
    // Schema:
    //   id               : string  (slug, e.g. 'credit-analysis')
    //   title            : string
    //   icon             : string  (Lucide icon name)
    //   shortDescription : string
    //   description      : string
    //   benefits         : string[]
    //   order            : number
    //
    // Access:
    //   READ   — anyone (services are shown on the public website)
    //   CREATE — admin only
    //   UPDATE — admin only
    //   DELETE — admin only

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
