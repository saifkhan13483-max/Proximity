# Site URL (used for canonical URLs and OG tags)
VITE_SITE_URL=https://proximity-credit-repair.replit.app

# Contact form API endpoint (POST endpoint that accepts JSON contact form data)
# Without this, the contact form will not submit and will prompt users to call directly.
# Compatible with services like Formspree (https://formspree.io) or a custom backend.
VITE_CONTACT_API_URL=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# Without this, analytics tracking is disabled.
VITE_ANALYTICS_ID=
