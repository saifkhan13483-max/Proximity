# Backend API base URL.
# In development this is proxied by Vite, so leave it pointing to localhost.
# In production (Vercel) API calls go through vercel.json rewrites, so this
# can be left empty or set to your Railway backend URL for direct calls.
VITE_API_URL=http://localhost:3001

# Canonical site URL used for SEO / Open Graph meta tags.
VITE_SITE_URL=https://your-app.vercel.app

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
VITE_ANALYTICS_ID=
