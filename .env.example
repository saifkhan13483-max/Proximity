# ── Firebase ───────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Google Gemini AI (server-side — Vercel / local dev) ─────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
# Add this as GEMINI_API_KEY (no VITE_ prefix) in Vercel → Settings → Environment Variables
# For local dev outside Replit, create a .env.local file with this key so the
# Vite dev-server proxy can forward requests to the Gemini API.
GEMINI_API_KEY=
