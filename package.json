{
  "name": "proximity-credit-repair",
  "private": true,
  "version": "1.0.0",
  "description": "Proximity Credit Repair — monorepo root. Frontend in /client (Vercel), backend in /firebase/functions (Firebase Functions).",
  "scripts": {
    "dev": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "preview": "npm run preview --prefix client",
    "install:all": "npm install && npm install --prefix client && npm install --prefix firebase/functions",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:export ./firebase/emulator-data",
    "emulators:import": "firebase emulators:start --import=./firebase/emulator-data",
    "deploy": "npm run deploy:functions && npm run deploy:firestore",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:all": "firebase deploy",
    "firebase:login": "firebase login",
    "firebase:use": "firebase use default",
    "lint": "npm run lint --prefix client",
    "typecheck": "npm run typecheck --prefix client"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0"
  }
}
