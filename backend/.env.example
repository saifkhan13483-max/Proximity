# Required — JWT signing secret. Must be a long, random string. Never use the default.
JWT_SECRET=

# Railway assigns the port automatically. Leave blank locally to use 3001.
PORT=3001

# Comma-separated list of allowed CORS origins.
# Include your Vercel frontend URL and localhost for local dev.
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,https://your-app.vercel.app
